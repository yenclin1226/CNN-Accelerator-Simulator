.PHONY : tests/benchmark_regression_tests.cpp.o

tests/benchmark_regression_tests.i: tests/benchmark_regression_tests.cpp.i
.PHONY : tests/benchmark_regression_tests.i

# target to preprocess a source file
tests/benchmark_regression_tests.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/benchmark_regression_tests.dir/build.make CMakeFiles/benchmark_regression_tests.dir/tests/benchmark_regression_tests.cpp.i
.PHONY : tests/benchmark_regression_tests.cpp.i


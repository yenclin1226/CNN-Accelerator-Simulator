.PHONY : tests/benchmark_regression_tests.s

# target to generate assembly for a file
tests/benchmark_regression_tests.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/benchmark_regression_tests.dir/build.make CMakeFiles/benchmark_regression_tests.dir/tests/benchmark_regression_tests.cpp.s
.PHONY : tests/benchmark_regression_tests.cpp.s

